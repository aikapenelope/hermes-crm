# =============================================================================
# hermes-crm — Environment variables
# Copy this file to .env and fill in your values before running docker compose.
#
# Generate strong passwords:
#   openssl rand -hex 32     → 64-char hex string (good for passwords)
#   openssl rand -base64 16  → 24-char base64 string (good for shorter passwords)
# =============================================================================

# ── Actor 1: Hermes MCP superuser ────────────────────────────────────────────
# Used by gaspechak-pocketbase-mcp to read/write all CRM data.
# Set in Hermes config.yaml under mcp_servers.crm.env.PB_EMAIL / PB_PASSWORD
PB_SUPERUSER_EMAIL=hermes@internal
PB_SUPERUSER_PASSWORD=change-me-with-openssl-rand-hex-32

# ── Actor 2: Business owner (CRM web UI login) ────────────────────────────────
# The human who logs into the CRM at http://<host>:8090 (or https://<domain>)
PB_USER_EMAIL=owner@yourcompany.com
PB_USER_PASSWORD=change-me-with-openssl-rand-base64-16

# ── Admin panel protection ────────────────────────────────────────────────────
# Space-separated IP addresses / CIDR ranges allowed to access /_/
# Built-in PocketBase feature — works without any reverse proxy.
#
# Recommended values:
#   Local dev only:      PB_ADMIN_IPS=127.0.0.1
#   VPS with SSH tunnel: PB_ADMIN_IPS=127.0.0.1
#   VPS + static home IP:PB_ADMIN_IPS=127.0.0.1 YOUR.HOME.IP.HERE
#   Tailscale network:   PB_ADMIN_IPS=127.0.0.1 100.64.0.0/10
#   No restriction:      leave empty (NOT recommended for internet-facing servers)
PB_ADMIN_IPS=127.0.0.1

# ── At-rest encryption (optional) ────────────────────────────────────────────
# Encrypts pb_data (SQLite + uploads). Requires --encryptionEnv flag.
# WARNING: if this key is lost, the database becomes UNREADABLE.
# Store this key separately from the database (e.g. password manager).
# Leave empty to skip encryption (acceptable for dev / internal networks).
# Generate: openssl rand -hex 16
PB_ENCRYPTION_KEY=

# ── Web port (optional) ───────────────────────────────────────────────────────
# Host port to expose the CRM on. Default: 8090
# Use 80 if running directly without a reverse proxy.
# Ignored when using the 'with-caddy' profile.
CRM_PORT=8090

# ── HTTPS domain (required only for --profile with-caddy) ────────────────────
# The domain name Caddy will obtain a TLS certificate for.
# Must point to this server before running Caddy.
# Example: crm.mycompany.com
DOMAIN=

# ── Hermes (optional — only if running Hermes in this compose) ───────────────
# OPENROUTER_API_KEY=sk-or-v1-...
# TELEGRAM_BOT_TOKEN=123456789:ABC...
# TELEGRAM_ALLOWED_USERS=123456789
